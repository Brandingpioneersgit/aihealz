{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    // TODO: Flip noImplicitAny to true once the ~112 implicit-any sites are
    // typed (mostly src/app/page.tsx and a handful of tools/* pages). Reverted
    // because flipping now would break the build.
    "noImplicitAny": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  // TODO: scripts/ is currently excluded — including it surfaces ~111 Prisma
  // type-drift errors in older one-off seed scripts. Re-include once those are
  // cleaned up or migrated.
  // Test files and the vitest config are excluded until `vitest` is added to
  // devDependencies (see README "Optional dev tooling not yet in lockfile").
  "exclude": [
    "node_modules",
    "scripts",
    "vitest.config.ts",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
