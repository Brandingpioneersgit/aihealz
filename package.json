{
  "name": "aihealz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "analyze": "next experimental-analyze",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,mjs,css,json,md}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,mjs,css,json,md}'",
    "test": "vitest",
    "test:ci": "vitest run",
    "generate:conditions": "npx tsx scripts/generate-conditions/batch-runner.ts",
    "generate:conditions:cardiology": "npx tsx scripts/generate-conditions/batch-runner.ts --specialty=Cardiology",
    "generate:conditions:all": "npx tsx scripts/generate-conditions/batch-runner.ts --all --concurrency=5",
    "generate:conditions:resume": "npx tsx scripts/generate-conditions/batch-runner.ts --resume",
    "validate:conditions": "npx tsx scripts/generate-conditions/batch-runner.ts --validate",
    "generate:conditions:stats": "npx tsx scripts/generate-conditions/batch-runner.ts --stats",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "seed:doctors": "npx tsx scripts/seed-doctors.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@stripe/stripe-js": "^8.11.0",
    "@tailwindcss/postcss": "^4.2.4",
    "autoprefixer": "^10.5.0",
    "bcryptjs": "^3.0.3",
    "dompurify": "^3.4.2",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "lightningcss": "^1.32.0",
    "lucide-react": "^0.575.0",
    "next": "16.2.5",
    "pg": "^8.18.0",
    "postcss": "^8.5.14",
    "prisma": "7.8.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "stripe": "^20.4.1",
    "tailwindcss": "^4.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "lightningcss-darwin-x64": "^1.32.0"
  }
}
