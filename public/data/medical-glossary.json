    { "id": "medications", "name": "Medications & Pharmacology", "icon": "💊" },
    { "id": "symptoms", "name": "Symptoms & Signs", "icon": "⚠️" },
    { "id": "specialties", "name": "Medical Specialties", "icon": "👨‍⚕️" },
    { "id": "abbreviations", "name": "Common Abbreviations", "icon": "📋" }
  ],
  "terms": [
    { "term": "Abdomen", "pronunciation": "AB-doh-men", "category": "anatomy", "definition": "The part of the body between the chest and pelvis, containing the digestive organs.", "related": ["Peritoneum", "Gastrointestinal"], "lastReviewed": "2025-01-15", "source": "Merriam-Webster Medical Dictionary" },
    { "term": "Acute", "pronunciation": "uh-KYOOT", "category": "conditions", "definition": "A condition with rapid onset and short duration, often severe. Opposite of chronic.", "related": ["Chronic", "Subacute"], "lastReviewed": "2025-01-15", "source": "MedlinePlus (NIH)" },
    { "term": "Adenoma", "pronunciation": "ad-eh-NOH-mah", "category": "conditions", "definition": "A benign tumor arising from glandular tissue.", "related": ["Adenocarcinoma", "Tumor", "Benign"], "lastReviewed": "2025-01-15", "source": "NCI Dictionary of Cancer Terms" },
    { "term": "Analgesic", "pronunciation": "an-al-JEE-zik", "category": "medications", "definition": "A medication that relieves pain without causing loss of consciousness.", "related": ["Anesthetic", "NSAID", "Opioid"], "lastReviewed": "2025-01-15", "source": "MedlinePlus (NIH)" },
    { "term": "Anemia", "pronunciation": "uh-NEE-mee-uh", "category": "conditions", "definition": "A condition with insufficient red blood cells or hemoglobin, causing fatigue and weakness.", "related": ["Hemoglobin", "Iron deficiency", "Blood"], "lastReviewed": "2025-01-15", "source": "NHLBI" },
    { "term": "Anesthesia", "pronunciation": "an-es-THEE-zhuh", "category": "procedures", "definition": "Loss of sensation, especially pain, induced by drugs for medical procedures.", "related": ["Local anesthesia", "General anesthesia", "Sedation"], "lastReviewed": "2025-01-15", "source": "ASA (American Society of Anesthesiologists)" },
    { "term": "Angioplasty", "pronunciation": "AN-jee-oh-plas-tee", "category": "procedures", "definition": "A procedure to open blocked arteries using a balloon catheter, often with stent placement.", "related": ["Stent", "Catheterization", "Coronary"], "lastReviewed": "2025-01-15", "source": "AHA (American Heart Association)" },
    { "term": "Antibiotic", "pronunciation": "an-tee-by-OT-ik", "category": "medications", "definition": "A medication that kills or inhibits the growth of bacteria.", "related": ["Antimicrobial", "Penicillin", "Resistance"], "lastReviewed": "2025-01-15", "source": "CDC" },
    { "term": "Arrhythmia", "pronunciation": "ah-RITH-mee-uh", "category": "conditions", "definition": "An irregular heartbeat, either too fast, too slow, or irregular rhythm.", "related": ["Tachycardia", "Bradycardia", "Atrial fibrillation"], "lastReviewed": "2025-01-15", "source": "AHA" },
    { "term": "Arthritis", "pronunciation": "ar-THRY-tis", "category": "conditions", "definition": "Inflammation of one or more joints, causing pain and stiffness.", "related": ["Osteoarthritis", "Rheumatoid arthritis", "Joint"], "lastReviewed": "2025-01-15", "source": "CDC" },
    { "term": "Biopsy", "pronunciation": "BY-op-see", "category": "procedures", "definition": "Removal of tissue sample for examination to diagnose disease.", "related": ["Pathology", "Histology", "Diagnosis"], "lastReviewed": "2025-01-15", "source": "NCI Dictionary of Cancer Terms" },
    { "term": "Benign", "pronunciation": "beh-NINE", "category": "conditions", "definition": "Not cancerous; a tumor that does not spread to other parts of the body.", "related": ["Malignant", "Tumor", "Cancer"], "lastReviewed": "2025-01-15", "source": "NCI Dictionary of Cancer Terms" },
    { "term": "Blood pressure", "pronunciation": "blud PRESH-ur", "category": "diagnostics", "definition": "The force of blood against artery walls, measured as systolic/diastolic (e.g., 120/80 mmHg).", "related": ["Hypertension", "Hypotension", "Systolic"], "lastReviewed": "2025-01-15", "source": "AHA" },
    { "term": "Bradycardia", "pronunciation": "brad-ee-KAR-dee-uh", "category": "symptoms", "definition": "An abnormally slow heart rate, typically below 60 beats per minute.", "related": ["Tachycardia", "Arrhythmia", "Heart rate"], "lastReviewed": "2025-01-15", "source": "AHA" },
    { "term": "Carcinoma", "pronunciation": "kar-sih-NOH-mah", "category": "conditions", "definition": "Cancer that begins in skin or tissue lining organs.", "related": ["Cancer", "Malignant", "Adenocarcinoma"], "lastReviewed": "2025-01-15", "source": "NCI Dictionary of Cancer Terms" },
    { "term": "Cardiac", "pronunciation": "KAR-dee-ak", "category": "anatomy", "definition": "Relating to the heart.", "related": ["Cardiovascular", "Coronary", "Heart"], "lastReviewed": "2025-01-15", "source": "Merriam-Webster Medical Dictionary" },
    { "term": "Catheter", "pronunciation": "KATH-eh-ter", "category": "procedures", "definition": "A thin tube inserted into the body to drain fluids or administer medications.", "related": ["Urinary catheter", "IV catheter", "Central line"], "lastReviewed": "2025-01-15", "source": "MedlinePlus (NIH)" },
    { "term": "CBC", "pronunciation": "see-bee-SEE", "category": "abbreviations", "definition": "Complete Blood Count - a blood test measuring red cells, white cells, and platelets.", "related": ["Blood test", "Hemoglobin", "WBC"], "lastReviewed": "2025-01-15", "source": "MedlinePlus (NIH)" },
    { "term": "Chronic", "pronunciation": "KRON-ik", "category": "conditions", "definition": "A condition persisting for a long time or constantly recurring. Opposite of acute.", "related": ["Acute", "Disease", "Long-term"], "lastReviewed": "2025-01-15", "source": "MedlinePlus (NIH)" },
    { "term": "Colonoscopy", "pronunciation": "koh-lon-OS-koh-pee", "category": "procedures", "definition": "Examination of the colon using a flexible scope inserted through the rectum.", "related": ["Endoscopy", "Colon", "Polyp"], "lastReviewed": "2025-01-15", "source": "ACS (American Cancer Society)" },
    { "term": "Computed Tomography (CT)", "pronunciation": "toh-MOG-ruh-fee", "category": "diagnostics", "definition": "X-ray imaging that creates detailed cross-sectional images of the body.", "related": ["X-ray", "MRI", "Scan", "CAT scan"], "lastReviewed": "2025-01-15", "source": "RadiologyInfo.org (RSNA)" },
    { "term": "Contraindication", "pronunciation": "kon-trah-in-dih-KAY-shun", "category": "medications", "definition": "A condition or factor that makes a treatment inadvisable.", "related": ["Side effect", "Drug interaction", "Precaution"], "lastReviewed": "2025-01-15", "source": "FDA" },
    { "term": "Coronary", "pronunciation": "KOR-oh-nair-ee", "category": "anatomy", "definition": "Relating to the arteries that supply blood to the heart muscle.", "related": ["Heart", "Cardiac", "Artery"], "lastReviewed": "2025-01-15", "source": "AHA" },
    { "term": "Dermatitis", "pronunciation": "der-mah-TY-tis", "category": "conditions", "definition": "Inflammation of the skin, causing redness, itching, and sometimes blistering.", "related": ["Eczema", "Skin", "Rash"], "lastReviewed": "2025-01-15", "source": "AAD (American Academy of Dermatology)" },
    { "term": "Diabetes", "pronunciation": "dy-uh-BEE-teez", "category": "conditions", "definition": "A metabolic disease causing high blood sugar due to insulin problems.", "related": ["Insulin", "Glucose", "Type 1", "Type 2"], "lastReviewed": "2025-01-15", "source": "ADA (American Diabetes Association)" },
    { "term": "Diagnosis", "pronunciation": "dy-ag-NOH-sis", "category": "diagnostics", "definition": "The identification of a disease or condition based on symptoms and tests.", "related": ["Prognosis", "Differential diagnosis", "Clinical"], "lastReviewed": "2025-01-15", "source": "Merriam-Webster Medical Dictionary" },
    { "term": "Dialysis", "pronunciation": "dy-AL-ih-sis", "category": "procedures", "definition": "A procedure to remove waste and excess fluid from blood when kidneys fail.", "related": ["Hemodialysis", "Kidney", "Renal failure"], "lastReviewed": "2025-01-15", "source": "NKF (National Kidney Foundation)" },
    { "term": "Dyspnea", "pronunciation": "DISP-nee-uh", "category": "symptoms", "definition": "Difficulty breathing or shortness of breath.", "related": ["Respiratory", "Breathlessness", "Apnea"], "lastReviewed": "2025-01-15", "source": "ATS (American Thoracic Society)" },
    { "term": "ECG/EKG", "pronunciation": "ee-see-JEE", "category": "abbreviations", "definition": "Electrocardiogram - a test that records the electrical activity of the heart.", "related": ["Heart", "Arrhythmia", "Cardiac"], "lastReviewed": "2025-01-15", "source": "AHA" },
    { "term": "Edema", "pronunciation": "eh-DEE-mah", "category": "symptoms", "definition": "Swelling caused by excess fluid trapped in body tissues.", "related": ["Swelling", "Fluid retention", "Lymphedema"], "lastReviewed": "2025-01-15", "source": "MedlinePlus (NIH)" },
    { "term": "Embolism", "pronunciation": "EM-boh-lizm", "category": "conditions", "definition": "Blockage of a blood vessel by a blood clot or other material.", "related": ["Thrombosis", "Pulmonary embolism", "Stroke"], "lastReviewed": "2025-01-15", "source": "NHLBI" },
    { "term": "Endocrinology", "pronunciation": "en-doh-krih-NOL-oh-jee", "category": "specialties", "definition": "The study of hormones and hormone-producing glands.", "related": ["Hormones", "Thyroid", "Diabetes"], "lastReviewed": "2025-01-15", "source": "Endocrine Society" },
    { "term": "Endoscopy", "pronunciation": "en-DOS-koh-pee", "category": "procedures", "definition": "Examination of internal organs using a flexible tube with a camera.", "related": ["Colonoscopy", "Gastroscopy", "Scope"], "lastReviewed": "2025-01-15", "source": "ASGE" },
    { "term": "Epidemiology", "pronunciation": "ep-ih-dee-mee-OL-oh-jee", "category": "specialties", "definition": "The study of disease distribution and patterns in populations.", "related": ["Public health", "Outbreak", "Statistics"], "lastReviewed": "2025-01-15", "source": "CDC" },
    { "term": "Gastroenterology", "pronunciation": "gas-troh-en-ter-OL-oh-jee", "category": "specialties", "definition": "Medical specialty focused on the digestive system.", "related": ["GI tract", "Stomach", "Intestines"], "lastReviewed": "2025-01-15", "source": "AGA (American Gastroenterological Association)" },
    { "term": "Hematology", "pronunciation": "hee-mah-TOL-oh-jee", "category": "specialties", "definition": "The study of blood and blood-forming organs.", "related": ["Blood", "Anemia", "Leukemia"], "lastReviewed": "2025-01-15", "source": "ASH (American Society of Hematology)" },
    { "term": "Hemorrhage", "pronunciation": "HEM-or-ij", "category": "conditions", "definition": "Severe or uncontrolled bleeding.", "related": ["Bleeding", "Blood loss", "Hemorrhagic"], "lastReviewed": "2025-01-15", "source": "MedlinePlus (NIH)" },
    { "term": "Hypertension", "pronunciation": "hy-per-TEN-shun", "category": "conditions", "definition": "Abnormally high blood pressure, increasing risk of heart disease and stroke.", "related": ["Blood pressure", "Cardiovascular", "Hypotension"], "lastReviewed": "2025-01-15", "source": "AHA" },
    { "term": "Hypotension", "pronunciation": "hy-poh-TEN-shun", "category": "conditions", "definition": "Abnormally low blood pressure, which may cause dizziness or fainting.", "related": ["Blood pressure", "Shock", "Hypertension"], "lastReviewed": "2025-01-15", "source": "AHA" },
    { "term": "Immunology", "pronunciation": "im-yoo-NOL-oh-jee", "category": "specialties", "definition": "The study of the immune system and immune responses.", "related": ["Immunity", "Autoimmune", "Allergy"], "lastReviewed": "2025-01-15", "source": "AAI (American Association of Immunologists)" },
    { "term": "Inflammation", "pronunciation": "in-flah-MAY-shun", "category": "symptoms", "definition": "Body's response to injury or infection, causing redness, heat, swelling, and pain.", "related": ["Immune response", "Infection", "Chronic"], "lastReviewed": "2025-01-15", "source": "NIH" },
    { "term": "Intravenous (IV)", "pronunciation": "in-trah-VEE-nus", "category": "procedures", "definition": "Administration of fluids or medications directly into a vein.", "related": ["Injection", "Catheter", "Infusion"], "lastReviewed": "2025-01-15", "source": "MedlinePlus (NIH)" },
    { "term": "Ischemia", "pronunciation": "is-KEE-mee-uh", "category": "conditions", "definition": "Insufficient blood supply to an organ or tissue, often due to blocked arteries.", "related": ["Coronary", "Stroke", "Necrosis"], "lastReviewed": "2025-01-15", "source": "AHA" },
    { "term": "Lesion", "pronunciation": "LEE-zhun", "category": "conditions", "definition": "Any abnormal tissue, wound, or area of damage in the body.", "related": ["Tumor", "Ulcer", "Wound"], "lastReviewed": "2025-01-15", "source": "Merriam-Webster Medical Dictionary" },
    { "term": "Lipid", "pronunciation": "LIP-id", "category": "diagnostics", "definition": "Fats in the blood including cholesterol and triglycerides.", "related": ["Cholesterol", "Triglycerides", "HDL", "LDL"], "lastReviewed": "2025-01-15", "source": "NHLBI" },
    { "term": "Magnetic Resonance Imaging (MRI)", "pronunciation": "em-ar-EYE", "category": "diagnostics", "definition": "Imaging technique using magnetic fields to create detailed images of organs and tissues.", "related": ["CT scan", "Imaging", "Radiology"], "lastReviewed": "2025-01-15", "source": "RadiologyInfo.org (RSNA)" },
    { "term": "Malignant", "pronunciation": "mah-LIG-nant", "category": "conditions", "definition": "Cancerous; tending to spread and invade other tissues.", "related": ["Benign", "Cancer", "Metastasis"], "lastReviewed": "2025-01-15", "source": "NCI Dictionary of Cancer Terms" },
    { "term": "Metabolism", "pronunciation": "meh-TAB-oh-lizm", "category": "anatomy", "definition": "Chemical processes in the body that convert food to energy.", "related": ["Metabolic", "Calories", "Energy"], "lastReviewed": "2025-01-15", "source": "MedlinePlus (NIH)" },
    { "term": "Metastasis", "pronunciation": "meh-TAS-tah-sis", "category": "conditions", "definition": "Spread of cancer from the original site to other parts of the body.", "related": ["Cancer", "Malignant", "Tumor"], "lastReviewed": "2025-01-15", "source": "NCI Dictionary of Cancer Terms" },
    { "term": "Nephrology", "pronunciation": "neh-FROL-oh-jee", "category": "specialties", "definition": "Medical specialty focused on kidney function and diseases.", "related": ["Kidney", "Dialysis", "Renal"], "lastReviewed": "2025-01-15", "source": "ASN (American Society of Nephrology)" },
    { "term": "Neurology", "pronunciation": "noo-ROL-oh-jee", "category": "specialties", "definition": "Medical specialty focused on the nervous system and its disorders.", "related": ["Brain", "Spine", "Stroke", "Epilepsy"], "lastReviewed": "2025-01-15", "source": "AAN (American Academy of Neurology)" },
    { "term": "NPO", "pronunciation": "en-pee-OH", "category": "abbreviations", "definition": "Nothing by mouth (nil per os) - instruction to not eat or drink before a procedure.", "related": ["Fasting", "Pre-operative", "Surgery"], "lastReviewed": "2025-01-15", "source": "ASA" },
    { "term": "Oncology", "pronunciation": "on-KOL-oh-jee", "category": "specialties", "definition": "Medical specialty focused on cancer diagnosis and treatment.", "related": ["Cancer", "Chemotherapy", "Radiation"], "lastReviewed": "2025-01-15", "source": "ASCO (American Society of Clinical Oncology)" },
    { "term": "Ophthalmology", "pronunciation": "of-thal-MOL-oh-jee", "category": "specialties", "definition": "Medical specialty focused on eye health and vision.", "related": ["Eye", "Vision", "Cataract"], "lastReviewed": "2025-01-15", "source": "AAO (American Academy of Ophthalmology)" },
    { "term": "Orthopedics", "pronunciation": "or-thoh-PEE-diks", "category": "specialties", "definition": "Medical specialty focused on bones, joints, and musculoskeletal system.", "related": ["Bone", "Joint", "Fracture"], "lastReviewed": "2025-01-15", "source": "AAOS" },
    { "term": "Pathology", "pronunciation": "pah-THOL-oh-jee", "category": "specialties", "definition": "The study of disease, especially through examination of tissues and body fluids.", "related": ["Biopsy", "Laboratory", "Diagnosis"], "lastReviewed": "2025-01-15", "source": "CAP (College of American Pathologists)" },
    { "term": "Pediatrics", "pronunciation": "pee-dee-AT-riks", "category": "specialties", "definition": "Medical specialty focused on health care of infants, children, and adolescents.", "related": ["Children", "Infant", "Development"], "lastReviewed": "2025-01-15", "source": "AAP (American Academy of Pediatrics)" },
    { "term": "Pneumonia", "pronunciation": "noo-MOH-nyah", "category": "conditions", "definition": "Infection that inflames air sacs in one or both lungs.", "related": ["Lung", "Respiratory", "Infection"], "lastReviewed": "2025-01-15", "source": "CDC" },
    { "term": "PRN", "pronunciation": "pee-ar-EN", "category": "abbreviations", "definition": "As needed (pro re nata) - take medication when necessary rather than on a schedule.", "related": ["Medication", "Dosage", "Prescription"], "lastReviewed": "2025-01-15", "source": "Merriam-Webster Medical Dictionary" },
    { "term": "Prognosis", "pronunciation": "prog-NOH-sis", "category": "diagnostics", "definition": "The likely course and outcome of a disease or condition.", "related": ["Diagnosis", "Outcome", "Survival"], "lastReviewed": "2025-01-15", "source": "Merriam-Webster Medical Dictionary" },
    { "term": "Psychiatry", "pronunciation": "sy-KY-uh-tree", "category": "specialties", "definition": "Medical specialty focused on mental health disorders.", "related": ["Mental health", "Psychology", "Depression"], "lastReviewed": "2025-01-15", "source": "APA (American Psychiatric Association)" },
    { "term": "Pulmonary", "pronunciation": "PUL-moh-nair-ee", "category": "anatomy", "definition": "Relating to the lungs.", "related": ["Lung", "Respiratory", "Breathing"], "lastReviewed": "2025-01-15", "source": "ATS" },
    { "term": "Radiology", "pronunciation": "ray-dee-OL-oh-jee", "category": "specialties", "definition": "Medical specialty using imaging to diagnose and treat diseases.", "related": ["X-ray", "CT", "MRI", "Ultrasound"], "lastReviewed": "2025-01-15", "source": "ACR (American College of Radiology)" },
    { "term": "Renal", "pronunciation": "REE-nal", "category": "anatomy", "definition": "Relating to the kidneys.", "related": ["Kidney", "Nephrology", "Dialysis"], "lastReviewed": "2025-01-15", "source": "NKF" },
    { "term": "Sepsis", "pronunciation": "SEP-sis", "category": "conditions", "definition": "Life-threatening condition caused by the body's response to infection.", "related": ["Infection", "Septic shock", "Blood poisoning"], "lastReviewed": "2025-01-15", "source": "CDC; Surviving Sepsis Campaign" },
    { "term": "Stat", "pronunciation": "STAT", "category": "abbreviations", "definition": "Immediately (statim) - an order for urgent action.", "related": ["Emergency", "Urgent", "Immediate"], "lastReviewed": "2025-01-15", "source": "Merriam-Webster Medical Dictionary" },
    { "term": "Stenosis", "pronunciation": "steh-NOH-sis", "category": "conditions", "definition": "Abnormal narrowing of a passage in the body.", "related": ["Aortic stenosis", "Spinal stenosis", "Blockage"], "lastReviewed": "2025-01-15", "source": "MedlinePlus (NIH)" },
    { "term": "Tachycardia", "pronunciation": "tak-ee-KAR-dee-uh", "category": "symptoms", "definition": "Abnormally rapid heart rate, typically over 100 beats per minute.", "related": ["Bradycardia", "Arrhythmia", "Heart rate"], "lastReviewed": "2025-01-15", "source": "AHA" },
    { "term": "Thrombosis", "pronunciation": "throm-BOH-sis", "category": "conditions", "definition": "Formation of a blood clot inside a blood vessel.", "related": ["DVT", "Embolism", "Clot"], "lastReviewed": "2025-01-15", "source": "NHLBI" },
    { "term": "Ultrasound", "pronunciation": "UL-trah-sownd", "category": "diagnostics", "definition": "Imaging technique using high-frequency sound waves to view internal organs.", "related": ["Sonography", "Imaging", "Prenatal"], "lastReviewed": "2025-01-15", "source": "RadiologyInfo.org (RSNA)" },
    { "term": "Urology", "pronunciation": "yoo-ROL-oh-jee", "category": "specialties", "definition": "Medical specialty focused on the urinary system and male reproductive organs.", "related": ["Kidney", "Bladder", "Prostate"], "lastReviewed": "2025-01-15", "source": "AUA (American Urological Association)" },
    { "term": "Vascular", "pronunciation": "VAS-kyoo-lar", "category": "anatomy", "definition": "Relating to blood vessels.", "related": ["Artery", "Vein", "Cardiovascular"], "lastReviewed": "2025-01-15", "source": "AHA" },
    { "term": "Vital signs", "pronunciation": "VY-tal synz", "category": "diagnostics", "definition": "Basic measurements of body function: temperature, pulse, blood pressure, respiratory rate.", "related": ["Blood pressure", "Heart rate", "Temperature"], "lastReviewed": "2025-01-15", "source": "MedlinePlus (NIH)" },

    { "term": "Cholecystectomy", "pronunciation": "koh-leh-sis-TEK-toh-mee", "category": "procedures", "definition": "Surgical removal of the gallbladder, commonly performed laparoscopically.", "related": ["Gallbladder", "Gallstones", "Laparoscopy"], "lastReviewed": "2025-01-15", "source": "ACS (American College of Surgeons)" },
    { "term": "Hernia", "pronunciation": "HUR-nee-uh", "category": "conditions", "definition": "Protrusion of an organ or tissue through a weak spot in surrounding muscle or connective tissue.", "related": ["Inguinal hernia", "Hiatal hernia", "Umbilical hernia"], "lastReviewed": "2025-01-15", "source": "MedlinePlus (NIH)" },
    { "term": "Stent", "pronunciation": "STENT", "category": "procedures", "definition": "A small mesh tube placed in a vessel or duct to keep it open.", "related": ["Angioplasty", "Coronary artery", "PCI"], "lastReviewed": "2025-01-15", "source": "AHA" },
    { "term": "Angioplasty (Balloon)", "pronunciation": "AN-jee-oh-plas-tee", "category": "procedures", "definition": "Procedure using a balloon catheter to dilate narrowed or blocked arteries.", "related": ["Stent", "PCI", "Atherosclerosis"], "lastReviewed": "2025-01-15", "source": "AHA" },
    { "term": "Glaucoma", "pronunciation": "glaw-KOH-mah", "category": "conditions", "definition": "Group of eye conditions causing optic nerve damage, often associated with elevated intraocular pressure.", "related": ["Intraocular pressure", "Optic nerve", "Vision loss"], "lastReviewed": "2025-01-15", "source": "AAO" },
    { "term": "Cataract", "pronunciation": "KAT-uh-rakt", "category": "conditions", "definition": "Clouding of the lens of the eye, leading to decreased vision.", "related": ["Lens", "Vision", "Cataract surgery"], "lastReviewed": "2025-01-15", "source": "AAO" },
    { "term": "Asthma", "pronunciation": "AZ-muh", "category": "conditions", "definition": "Chronic inflammatory airway disease causing wheezing, shortness of breath, and cough.", "related": ["Bronchodilator", "Inhaler", "Allergy"], "lastReviewed": "2025-01-15", "source": "GINA (Global Initiative for Asthma)" },
    { "term": "COPD", "pronunciation": "see-oh-pee-DEE", "category": "conditions", "definition": "Chronic Obstructive Pulmonary Disease - progressive lung disease causing airflow limitation, including emphysema and chronic bronchitis.", "related": ["Emphysema", "Bronchitis", "Smoking"], "lastReviewed": "2025-01-15", "source": "GOLD (Global Initiative for Chronic Obstructive Lung Disease)" },
    { "term": "Eczema", "pronunciation": "EK-zuh-muh", "category": "conditions", "definition": "Group of inflammatory skin conditions (most commonly atopic dermatitis) causing itchy, red, dry skin.", "related": ["Atopic dermatitis", "Allergy", "Skin"], "lastReviewed": "2025-01-15", "source": "AAD" },
    { "term": "Psoriasis", "pronunciation": "soh-RY-uh-sis", "category": "conditions", "definition": "Chronic autoimmune skin disease producing thick, scaly plaques.", "related": ["Skin", "Autoimmune", "Plaque"], "lastReviewed": "2025-01-15", "source": "AAD" },
    { "term": "Bronchitis", "pronunciation": "brong-KY-tis", "category": "conditions", "definition": "Inflammation of the bronchial tubes, acute or chronic, causing cough and mucus production.", "related": ["Cough", "COPD", "Respiratory"], "lastReviewed": "2025-01-15", "source": "ATS" },
    { "term": "Migraine", "pronunciation": "MY-grayn", "category": "conditions", "definition": "Recurrent headache disorder, typically unilateral, throbbing, often with nausea and light sensitivity.", "related": ["Headache", "Aura", "Photophobia"], "lastReviewed": "2025-01-15", "source": "AAN" },
    { "term": "Stroke", "pronunciation": "STROHK", "category": "conditions", "definition": "Acute neurological injury due to disruption of blood supply to the brain (ischemic or hemorrhagic).", "related": ["TIA", "Ischemia", "Hemorrhage"], "lastReviewed": "2025-01-15", "source": "AHA/ASA" },
    { "term": "Aneurysm", "pronunciation": "AN-yoo-riz-um", "category": "conditions", "definition": "Abnormal bulge in the wall of a blood vessel that may rupture.", "related": ["Aorta", "Subarachnoid hemorrhage", "Vascular"], "lastReviewed": "2025-01-15", "source": "AHA" },
