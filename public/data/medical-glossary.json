    { "term": "Melanoma", "pronunciation": "mel-uh-NOH-muh", "category": "conditions", "definition": "Most serious type of skin cancer, arising from pigment-producing melanocytes.", "related": ["Skin cancer", "Mole", "UV radiation"], "lastReviewed": "2025-01-15", "source": "AAD; ACS" },
